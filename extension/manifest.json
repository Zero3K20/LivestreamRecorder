{
  "manifest_version": 3,
  "name": "Livestream Recorder",
  "version": "2.0.0",
  "description": "Record live streams (HLS/m3u8, FLV, MP4, WebSocket) directly to disk. Downloads continue in the background even after you leave the page.",
  "permissions": ["storage"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content_hooks.js"],
      "run_at": "document_start",
      "world": "MAIN",
      "all_frames": false
    },
    {
      "matches": ["<all_urls>"],
      "js": ["content_bridge.js"],
      "run_at": "document_start",
      "all_frames": false
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Livestream Recorder"
  }
}
